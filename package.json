    "desktop:dev": "npm run sidecar && tauri dev",
    "desktop:build": "npm run sidecar && tauri build"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
