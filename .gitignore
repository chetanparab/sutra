# dependencies
node_modules/

# build output
dist/
dist-ssr/
*.tsbuildinfo

# native (Tauri) build artifacts
src-tauri/target/

# secrets & local env — never commit
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.secrets

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
Thumbs.db

# misc
*.local

# engine eval fixtures are generated at run time (real nested git repos) — never
# committed, see engine/evals/fixtures/makeToyRepo.ts
engine/evals/fixtures/*/
dist-sidecar/
src-tauri/target/
src-tauri/gen/
.cargo/
